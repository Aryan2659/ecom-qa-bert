# Copy to .env and edit. All values below are defaults — override only
# what you need.

# ── QA Model (for spec questions) ──────────────────────────────────
HF_MODEL_NAME=deepset/bert-base-cased-squad2
MAX_CONTEXT_CHARS=2500
MAX_SEQ_LENGTH=512
WARMUP_ON_START=true

# ── Sentiment Model (for review questions) ─────────────────────────
SENTIMENT_MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
SENTIMENT_MAX_REVIEWS=50
SENTIMENT_BATCH_SIZE=8

# ── Scraper ────────────────────────────────────────────────────────
SCRAPE_TIMEOUT=25
SCRAPE_MAX_RETRIES=3

# ── Playwright (headless browser) ──────────────────────────────────
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_MAX_REVIEWS=50
PLAYWRIGHT_HEADLESS=true

# ── Rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SCRAPE=10 per minute
RATE_LIMIT_PREDICT=30 per minute
RATE_LIMIT_DEFAULT=200 per hour

# ── Persistence ────────────────────────────────────────────────────
# DB_PATH=/data/history.db
HISTORY_LIMIT=100

# ── Server ─────────────────────────────────────────────────────────
PORT=7860
FLASK_DEBUG=false
